{
  "expo": {
    "name": "TrackCast",
    "slug": "trackcast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/TrackCast_logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/TrackCast_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "com.azizbek.trackcast",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "FOREGROUND_SERVICE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/TrackCast_logo.png",
        "backgroundColor": "#000000"
      },
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "extra": {
      "eas": {
        "projectId": "3f1bc36c-5f63-446d-9a49-141d1d4efefd"
      }
    }
  }
}
