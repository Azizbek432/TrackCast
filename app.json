{
  "expo": {
    "name": "TrackCast",
    "slug": "trackcast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/TrackCast_logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/TrackCast_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow TrackCast to use the camera for AR HUD.",
          "recordAudioPermission": "Allow TrackCast to record audio."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow TrackCast to use your location for speed tracking."
        }
      ],
      "expo-sqlite",
      "expo-font"
    ],
    "android": {
      "package": "com.azizbek.trackcast",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/TrackCast_logo.png",
        "backgroundColor": "#000000"
      },
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "extra": {
      "eas": {
        "projectId": "3f1bc36c-5f63-446d-9a49-141d1d4efefd"
      }
    }
  }
}
